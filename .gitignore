# =============================================================================
# Open DQA — .gitignore
# =============================================================================

# ── Patient / Clinical Data (NEVER commit) ───────────────────────────────────
*.csv
*.xlsx
*.xls
!data/Test_Data.csv
!data/open_dqa_expected_hits.csv
!data/OpenDQA_Checks_Metadata.xlsx
*.json
*.xml
*.hl7
*.fhir

# ── Configuration with Secrets ───────────────────────────────────────────────
.Renviron
config/secrets.yml
config/email_credentials.yml
*.key
*.pem
*.env

# ── R / RStudio ───────────────────────────────────────────────────────────────
.Rhistory
.RData
.Ruserdata
*.Rproj.user/
rsconnect/

# ── Session & Log Files ───────────────────────────────────────────────────────
logs/
!logs/.gitkeep
sessions/

# ── Report Output ─────────────────────────────────────────────────────────────
reports/output/
*.pdf
*.html
!docs/**/*.html

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo
*~

# ── TinyTeX / LaTeX Artifacts ─────────────────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# ── Node (if any JS tooling) ─────────────────────────────────────────────────
node_modules/
